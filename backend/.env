VISION_MOCK_MODE=false
DATABASE_PATH=data/vision_assistant.sqlite3
UPLOAD_DIR=data/uploads
KEYFRAME_DIR=data/keyframes
FRAME_SAMPLE_SECONDS=1.5
ALERT_COOLDOWN_SECONDS=20

# Replace with your real LLM API details (e.g., OpenAI, Anthropic, or local Ollama)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o-mini

# Replace with the URL of your VLM running on the cloud AMD GPU
VLM_BASE_URL=https://your-amd-cloud-vlm.com/v1
VLM_API_KEY=your_vlm_api_key_here
VLM_MODEL=qwen-vl

