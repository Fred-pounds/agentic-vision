VISION_MOCK_MODE=false
DATABASE_PATH=data/vision_assistant.sqlite3
UPLOAD_DIR=data/uploads
KEYFRAME_DIR=data/keyframes
FRAME_SAMPLE_SECONDS=1.5
ALERT_COOLDOWN_SECONDS=20

# Use the same Qwen-VL model on AMD for querying
LLM_BASE_URL=http://165.245.136.5:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

# Replace with the URL of your VLM running on the cloud AMD GPU
VLM_BASE_URL=http://165.245.136.5:8000/v1
VLM_API_KEY=not-needed
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct

